{
  "name": "ai-mail",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @mail-ai/server --filter @mail-ai/web dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @mail-ai/server db:generate",
    "db:migrate": "pnpm --filter @mail-ai/server db:migrate"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
