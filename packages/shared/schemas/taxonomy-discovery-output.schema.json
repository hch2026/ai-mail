{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mailboxProfile",
    "categories",
    "clusterAssignments",
    "uncertainClusters",
    "possiblePromotions",
    "quality"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["taxonomy-discovery.v1"]
    },
    "mailboxProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalEmails", "dateRange", "totalClusters", "analyzedClusters"],
      "properties": {
        "totalEmails": { "type": "integer", "minimum": 0 },
        "dateRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {
            "from": {
              "anyOf": [
                { "type": "string", "format": "date-time" },
                { "type": "null" }
              ]
            },
            "to": {
              "anyOf": [
                { "type": "string", "format": "date-time" },
                { "type": "null" }
              ]
            }
          }
        },
        "totalClusters": { "type": "integer", "minimum": 0 },
        "analyzedClusters": { "type": "integer", "minimum": 0 }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 8,
      "maxItems": 18,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "description",
          "inclusionRules",
          "exclusionRules",
          "estimatedCount",
          "examples",
          "isFallback"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "maxLength": 48,
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "name": { "type": "string", "minLength": 1, "maxLength": 40 },
          "description": { "type": "string", "minLength": 1, "maxLength": 240 },
          "inclusionRules": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": { "type": "string", "minLength": 1, "maxLength": 240 }
          },
          "exclusionRules": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": { "type": "string", "minLength": 1, "maxLength": 240 }
          },
          "estimatedCount": { "type": "integer", "minimum": 0 },
          "examples": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sender", "subject"],
              "properties": {
                "sender": { "type": "string", "minLength": 1, "maxLength": 320 },
                "subject": { "type": "string", "minLength": 1, "maxLength": 500 }
              }
            }
          },
          "isFallback": { "type": "boolean" }
        }
      }
    },
    "clusterAssignments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "clusterId",
          "categoryId",
          "sourceLabels",
          "actionRequired",
          "suspectedPromotion",
          "confidence",
          "mixed",
          "reason"
        ],
        "properties": {
          "clusterId": { "type": "integer", "minimum": 1 },
          "categoryId": {
            "type": "string",
            "minLength": 2,
            "maxLength": 48,
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "sourceLabels": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 80 }
          },
          "actionRequired": { "type": "boolean" },
          "suspectedPromotion": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "mixed": { "type": "boolean" },
          "reason": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      }
    },
    "uncertainClusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clusterId", "reason"],
        "properties": {
          "clusterId": { "type": "integer", "minimum": 1 },
          "reason": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      }
    },
    "possiblePromotions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clusterId", "reason", "confidence"],
        "properties": {
          "clusterId": { "type": "integer", "minimum": 1 },
          "reason": { "type": "string", "minLength": 1, "maxLength": 200 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coverage", "estimatedFallbackRate", "warnings"],
      "properties": {
        "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "estimatedFallbackRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "warnings": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    }
  }
}
