# Required primary 163 account. Use a client authorization code, never the web password.
MAIL_EMAIL=your-name@163.com
MAIL_IMAP_HOST=imap.163.com
MAIL_IMAP_PORT=993
MAIL_IMAP_SECURE=true
MAIL_AUTH_CODE=replace-with-your-163-client-authorization-code
MAIL_MAILBOX=INBOX
MAIL_163_DISPLAY_NAME=163邮箱
# Leave false until you have verified account selection and dry-run deletion.
MAIL_163_WRITE_ENABLED=false

# Optional QQ account. First enable IMAP/SMTP in QQ Mail settings and generate an
# authorization code. The application only uses IMAP and does not implement SMTP.
MAIL_QQ_ENABLED=false
MAIL_QQ_DISPLAY_NAME=QQ邮箱
MAIL_QQ_EMAIL=your-number@qq.com
MAIL_QQ_AUTH_CODE=replace-with-your-qq-client-authorization-code
MAIL_QQ_IMAP_HOST=imap.qq.com
MAIL_QQ_IMAP_PORT=993
MAIL_QQ_IMAP_SECURE=true
MAIL_QQ_MAILBOX=INBOX
# QQ remains read-only/dry-run until this is explicitly changed to true.
MAIL_QQ_WRITE_ENABLED=false

# Local SQLite and API runtime. In local development this relative path resolves
# under apps/server; Docker Compose overrides it to /data/mail.db.
DATABASE_URL=./data/mail.db
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
WEB_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Legacy fallback for the 163 account when MAIL_163_WRITE_ENABLED is omitted.
DRY_RUN=true
SYNC_PAGE_SIZE=200
SYNC_POLL_INTERVAL_SECONDS=300
SYNC_IDLE_FAILURE_THRESHOLD=3
SYNC_LOCK_TTL_SECONDS=900
SYNC_FULL_FLAG_REFRESH_SECONDS=3600

# Optional model classifier. Leave AI_API_KEY and AI_MODEL empty to use local rules.
# Classification still waits for a user-confirmed taxonomy.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=30000
MAX_ATTACHMENT_BYTES=26214400
